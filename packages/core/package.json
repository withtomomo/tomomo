{
  "name": "@tomomo/core",
  "version": "0.1.0",
  "description": "Core business logic for Tomomo.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./character": {
      "types": "./dist/character.d.ts",
      "import": "./dist/character.js"
    }
  },
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
